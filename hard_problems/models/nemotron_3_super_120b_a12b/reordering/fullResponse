package hard_problems.reordering;

import java.util.HashSet;
import java.util.Set;
import java.util.concurrent.CountDownLatch;

public class ReorderingProblem_NonVolatile {

    // plain fields
    static int w = 0, x = 0;
    static int y = 0, z = 0;

    private static void runOneIteration() throws InterruptedException {
        CountDownLatch latch = new CountDownLatch(2);
        w = x = y = z = 0;               // reset shared state

        Thread t1 = new Thread(() -> {
            latch.countDown();
            try { latch.await(); } catch (InterruptedException ignored) {}
            w = 1;                       // volatile write would be here if we changed the field
            y = x;                       // read of the *other* field
        });

        Thread t2 = new Thread(() -> {
            latch.countDown();
            try { latch.await(); } catch (InterruptedException ignored) {}
            x = 1;
            z = w;                       // read of the *other* field
        });

        t1.start();
        t2.start();
        t1.join();
        t2.join();
    }

    public static void main(String[] args) throws InterruptedException {
        Set<String> seen = new HashSet<>();
        int iteration = 0;
        while (seen.size() < 4) {
            runOneIteration();
            String out = "(" + y + ", " + z + ")";
            seen.add(out);
            System.out.printf("Iteration %3d → %s%n", iteration, out);
            iteration++;
        }
        System.out.println("\nAll four possible outputs observed: " + seen);
    }
}
